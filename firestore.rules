rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn(); /* Removed email_verified check for anonymous testing */ }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    // --- VALIDATOR BLUEPRINTS ---
    function isValidLibraryComponent(data) {
      return data.keys().hasAll(['name', 'type', 'createdAt'])
        && data.keys().size() == 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.type is string && data.type.size() <= 100
        && data.createdAt is string && data.createdAt.size() <= 100;
    }

    function isValidMediaSize(data) {
      return data.keys().hasAll(['name', 'dimensions'])
        && data.keys().size() == 2
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.dimensions is string && data.dimensions.size() > 0 && data.dimensions.size() <= 200;
    }

    function isValidFinishedSize(data) {
      return data.keys().hasAll(['name', 'dimensions', 'compatibleMediaSizeIds'])
        && data.keys().size() == 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.dimensions is string && data.dimensions.size() > 0 && data.dimensions.size() <= 200
        && data.compatibleMediaSizeIds is list && data.compatibleMediaSizeIds.size() <= 100;
    }

    function isValidSavedProduct(data) {
      return data.keys().hasAll(['name'])
        && data.keys().size() == 1
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    function isValidPrintCustomer(data) {
       return data.keys().hasAll(['accountNumber', 'companyName', 'city', 'state', 'threePP', 'printToStore'])
         && data.keys().size() == 6
         && data.accountNumber is string && data.accountNumber.size() > 0 && data.accountNumber.size() <= 128
         && data.companyName is string && data.companyName.size() > 0 && data.companyName.size() <= 200
         && data.city is string && data.city.size() <= 200
         && data.state is string && data.state.size() <= 200
         && data.threePP is string && data.threePP.size() <= 100
         && data.printToStore is bool;
    }

    function isValidCustomerNote(data) {
       return data.keys().hasAll(['author', 'date', 'text', 'isPinned', 'createdAt'])
         && data.keys().size() == 5
         && data.author is string && data.author.size() > 0 && data.author.size() <= 200
         && data.date is string && data.date.size() > 0 && data.date.size() <= 50
         && data.text is string && data.text.size() <= 10000
         && data.isPinned is bool
         && data.createdAt is string && data.createdAt.size() <= 100;
    }

    function isValidFileAsset(data) {
      return data.keys().hasAll(['name'])
        && data.keys().size() == 1
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    match /appData/{docId} {
      // Broadly allow get, list, create, update, delete for prototype sharing across users without requiring authentication
      allow read, write: if isValidId(docId);
    }
  }
}
